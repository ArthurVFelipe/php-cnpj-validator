{
    "name": "avf/cnpj",
    "description": "Validador de CNPJ numérico e alfanumérico para PHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "cnpj",
        "validator",
        "brasil",
        "documento",
        "alfanumerico",
        "cpf-cnpj"
    ],
    "autoload": {
        "psr-4": {
            "Avf\\Cnpj\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Avf\\Cnpj\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Arthur Felipe"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "scripts": {
        "test": "phpunit"
    },

    "homepage": "https://github.com/ArthurVFelipe/php-cnpj-validator",
    "support": {
        "issues": "https://github.com/ArthurVFelipe/php-cnpj-validator/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/ArthurVFelipe/php-cnpj-validator.git"
    }
}